---
import '../index.css';
const { frontmatter } = Astro.props;

// Existing Breadcrumb Logic
const breadcrumbText = frontmatter.breadcrumb || "< cd ~/home";
const breadcrumbLink = frontmatter.breadcrumbLink || "/";

// New variables for Top Right Links (pulled from markdown)
const githubLink = frontmatter.githubLink;
const videoLink = frontmatter.videoLink;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{frontmatter.title}</title>
</head>
<body class="bg-[#0D1117] text-[#C9D1D9] font-mono p-6 md:p-12 max-w-4xl mx-auto">
    
    <!-- Updated Navigation Bar -->
    <nav class="mb-12 border-b border-[#30363D] pb-4 flex flex-wrap justify-between items-center gap-4">
        
        <!-- Left Side: Breadcrumb -->
        <a href={breadcrumbLink} class="text-[#58A6FF] hover:text-[#79C0FF] transition-colors decoration-none whitespace-nowrap">
            {breadcrumbText}
        </a>
        
        <!-- Right Side: Links (Only render if provided in markdown) -->
        <div class="flex gap-6 items-center">
            {videoLink && (
                <a href={videoLink} target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-[#ff7b72] transition-colors flex items-center gap-2 text-sm decoration-none">
                    <svg viewBox="0 0 24 24" class="w-4 h-4 fill-current" xmlns="http://www.w3.org/2000/svg"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                    Video
                </a>
            )}
            
            {githubLink && (
                <a href={githubLink} target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-[#58a6ff] transition-colors flex items-center gap-2 text-sm decoration-none">
                    <svg viewBox="0 0 24 24" class="w-4 h-4 fill-current" xmlns="http://www.w3.org/2000/svg"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
                    Code
                </a>
            )}
        </div>
    </nav>

    <main class="prose prose-invert prose-pre:bg-[#161B22] prose-pre:border prose-pre:border-[#30363D] max-w-none">
        <slot />
    </main>

</body>
</html>