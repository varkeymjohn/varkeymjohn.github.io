---
const { name, class: className = '', ...attrs } = Astro.props;
---

<!-- Bypasses the local subset by pulling the standard Material Icons font -->
<link href="https://fonts.googleapis.com/icon?family=Material+Icons+Outlined" rel="stylesheet" />

<span 
  class={`material-icons-outlined ${className}`} 
  style="font-family: 'Material Icons Outlined' !important; text-transform: none !important; letter-spacing: normal !important; word-wrap: normal !important; white-space: nowrap !important;" 
  {...attrs}
>
  {name}
</span>