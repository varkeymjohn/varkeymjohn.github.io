---
const { name, class: className = '', ...attrs } = Astro.props;
---

<!-- 1. Import the full library with a specific THIN weight (200) -->
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,200,0,0" rel="stylesheet" />

<!-- 2. Apply the font directly without using the theme's broken class name -->
<span 
  class={className} 
  style="font-family: 'Material Symbols Outlined' !important; font-variation-settings: 'wght' 200, 'opsz' 24 !important; text-transform: none !important; letter-spacing: normal !important; white-space: nowrap !important; word-wrap: normal !important; display: inline-block;" 
  {...attrs}
>
  {name}
</span>