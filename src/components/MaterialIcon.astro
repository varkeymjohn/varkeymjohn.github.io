---
const { name, class: className = '', ...attrs } = Astro.props;
---

<!-- Import the full library with a specific THIN weight (200) -->
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,200,0,0" rel="stylesheet" />

<span 
  class={className} 
  style="font-family: 'Material Symbols Outlined' !important; font-size: inherit !important; font-variation-settings: 'wght' 200, 'opsz' 24 !important; text-transform: none !important; letter-spacing: normal !important; white-space: nowrap !important; word-wrap: normal !important; display: inline-block; vertical-align: bottom;" 
  {...attrs}
>
  {name}
</span>