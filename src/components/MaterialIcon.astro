---
const { name, class: className = '', ...attrs } = Astro.props;
---

<style>
  /* 
    1. Pull the full Material Symbols library directly into the component.
    2. Specifically request font weight 300 (thin/elegant) to match your theme.
  */
  @import url('https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,300,0,0');

  .force-symbol {
    font-family: 'Material Symbols Outlined' !important;
    font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24 !important;
    text-transform: none !important;
    letter-spacing: normal !important;
    white-space: nowrap !important;
    word-wrap: normal !important;
  }
</style>

<span class={`material-symbols-outlined force-symbol ${className}`} {...attrs}>
  {name}
</span>