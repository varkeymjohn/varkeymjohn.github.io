---
import MaterialIcon from './MaterialIcon.astro';
import { siteConfig } from '../config/site';

const { sections, toolCategories } = siteConfig;
const toolstack = sections.toolstack;
---

<section id="toolstack" aria-labelledby="toolstack-title" class="scroll-mt-32">
  <div class="flex items-center gap-4 mb-12 reveal-heading" data-reveal="left">
    <h2 id="toolstack-title" class="text-3xl text-white font-mono uppercase">{toolstack.heading}</h2>
    <div aria-hidden="true" class="h-px bg-gray-800 flex-1"></div>
  </div>

  <div class="border border-gray-800 bg-[#05080D]/80 shadow-[0_0_0_1px_rgba(0,255,0,0.03)] reveal-static" data-reveal>
    <div class="flex items-center justify-between gap-4 border-b border-gray-800 bg-[#161B22]/60 px-4 py-3 font-mono text-xs text-gray-300">
      <div aria-hidden="true" class="flex items-center gap-2">
        <span class="h-2.5 w-2.5 rounded-full bg-[#00FF00]/70"></span>
        <span class="h-2.5 w-2.5 rounded-full bg-gray-700"></span>
        <span class="h-2.5 w-2.5 rounded-full bg-gray-700"></span>
      </div>
      <span>{toolstack.terminalTitle}</span>
    </div>

    <div class="p-4 md:p-6 font-mono">
      <div class="mb-5 flex items-center gap-1.5 overflow-x-auto whitespace-nowrap text-xs text-gray-400 md:text-sm">
        <span class="text-[#00FF00]">{toolstack.promptUser}</span>
        <span aria-hidden="true" class="text-gray-700">:</span>
        <span class="text-gray-300">{toolstack.promptPath}</span>
        <span aria-hidden="true" class="text-gray-700">$</span>
        <span>{toolstack.command}</span>
      </div>

      <div class="hidden md:grid grid-cols-[120px_92px_92px_1fr] gap-4 border-b border-gray-800 pb-3 text-xs uppercase tracking-widest text-gray-300">
        <span>mode</span>
        <span>owner</span>
        <span>size</span>
        <span>toolchain</span>
      </div>

      <div class="divide-y divide-gray-900">
        {toolCategories.map((cat, i) => (
          <article class="grid gap-3 py-5 md:grid-cols-[120px_92px_92px_1fr] md:gap-4" data-reveal="left" style={`--reveal-delay: ${i * 90}ms`}>
            <div class="flex items-center gap-2 text-xs text-[#00FF00]">
              <MaterialIcon name="folder" class="text-base" aria-hidden="true" />
              <span>drwxr-x---</span>
            </div>
            <div class="text-xs text-gray-300"><span class="sr-only">Owner: </span>{cat.owner}</div>
            <div class="text-xs text-gray-300"><span class="sr-only">Size: </span>{cat.size}</div>
            <div>
              <div class="mb-3 flex items-center gap-2 text-sm text-gray-200">
                <MaterialIcon name="memory" class="text-base" aria-hidden="true" />
                <span>./{cat.name}</span>
              </div>
              <div class="flex flex-wrap gap-2">
                {cat.tools.map((tool) => (
                  <span class="border border-gray-800 bg-[#0D1117] px-2.5 py-1 text-xs text-gray-300 transition-colors hover:border-[#00FF00]/40 hover:text-gray-200">
                    {tool}
                  </span>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>

      <div class="mt-4 border-t border-gray-900 pt-4 text-xs text-gray-300">
        <span class="text-[#00FF00]">{toolstack.summary.directories}</span> directories indexed, <span class="text-[#00FF00]">{toolstack.summary.tools}</span> tools ready
      </div>
    </div>
  </div>
</section>
